{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissoes do Painel Pantero IA (API + Browser)",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "api",
          "sidecar": true
        }
      ]
    },
    "shell:allow-open"
  ]
}